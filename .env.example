# ============================================================================
# FortressWAF - Environment Variables
# ============================================================================
# Copy this file to .env and modify as needed:
#   cp .env.example .env
# ============================================================================

# --- Build Metadata ---
VERSION=latest
COMMIT=
BUILD_DATE=

# --- Proxy Ports ---
PROXY_HTTP_PORT=80
PROXY_HTTPS_PORT=443
PROXY_ADMIN_PORT=8443

# --- Dashboard ---
DASHBOARD_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8443/api/v1

# --- ML Engine ---
ML_ENGINE_PORT=8000
ML_LOG_LEVEL=info

# --- PostgreSQL ---
DB_NAME=fortresswaf
DB_USER=fortress
DB_PASSWORD=fortress
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PASSWORD=fortress
REDIS_PORT=6379

# --- NATS ---
NATS_PORT=4222
NATS_MONITOR_PORT=8222

# --- OpenSearch ---
OPENSEARCH_PASSWORD=FortressWAF123!
OPENSEARCH_PORT=9200
OPENSEARCH_PERF_PORT=9600

# --- Admin API ---
ADMIN_JWT_SECRET=change-me-in-production

# --- Monitoring (optional) ---
GRAFANA_PASSWORD=admin
SMTP_PASSWORD=
SLACK_WEBHOOK_URL=
PAGERDUTY_SERVICE_KEY=

# --- Timezone ---
TZ=UTC
